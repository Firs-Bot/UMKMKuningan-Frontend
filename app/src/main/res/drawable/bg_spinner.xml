<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <stroke android:width="1dp" android:color="#BDBDBD" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:right="12dp" android:gravity="end|center_vertical">
        <!-- Built-in small down arrow from Android framework -->
        <bitmap android:src="@android:drawable/arrow_down_float" android:tint="@color/textColorSecondary" />
    </item>
</layer-list>
